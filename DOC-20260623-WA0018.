        /* =========================================
           2. APP STATE VARIABLES
        ========================================= */
        let currentQIndex = 0;
        let scoreXP = 0;
        let correctCount = 0;
        let wrongCount = 0;
        
        let timerInterval;
        let timeLeft = 30;
        let isPaused = false;
        let isAnswering = false;
        
        let startTime = 0;
        
        // Analytics
        const unitStats = {
            "Unit-1: Atomic Structure": { total: 12, correct: 0 },
            "Unit-2: Water": { total: 10, correct: 0 },
            "Unit-3: Engineering Materials": { total: 10, correct: 0 },
            "Unit-4: Solid State": { total: 8, correct: 0 },
            "Unit-5: Electrochemistry": { total: 10, correct: 0 }
        };

        /* =========================================
           3. BACKGROUND ANIMATIONS
        ========================================= */
        function createBackgroundAtoms() {
            const container = document.getElementById('bg-anims');
            for(let i=0; i<15; i++) {
                let atom = document.createElement('div');
                atom.className = 'atom';
                let size = Math.random() * 50 + 20;
                atom.style.width = size + 'px';
                atom.style.height = size + 'px';
                atom.style.left = Math.random() * 100 + 'vw';
                atom.style.animationDuration = (Math.random() * 10 + 10) + 's';
                atom.style.animationDelay = (Math.random() * 5) + 's';
                container.appendChild(atom);
            }
        }
        createBackgroundAtoms();

        /* =========================================
           4. TEXT TO SPEECH (AI TEACHER)
        ========================================= */
        const synth = window.speechSynthesis;
        let aiVoice = null;

        function setVoice() {
            const voices = synth.getVoices();
            aiVoice = voices.find(v => v.lang.includes('hi') || v.lang.includes('IN')) || voices[0];
        }
        synth.onvoiceschanged = setVoice;

        function speakText(text, callback = null, rate = 0.95) {
            synth.cancel();
            if(!text) return;
            const utterance = new SpeechSynthesisUtterance(text);
            if(aiVoice) utterance.voice = aiVoice;
            utterance.lang = 'hi-IN';
            utterance.rate = rate;
            utterance.pitch = 1.1; // Slightly higher pitch for teacher feel

            if(callback) {
                utterance.onend = callback;
                setTimeout(() => { if(synth.speaking) return; callback(); }, 5000 + text.length * 100);
            }
            synth.speak(utterance);
        }

        /* =========================================
           5. SPEECH RECOGNITION
        ========================================= */
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        let recognition = null;
        let isListening = false;
        const elAiStatus = document.getElementById('ai-status');
        const btnMic = document.getElementById('mic-btn');

        if(SpeechRecognition) {
            recognition = new SpeechRecognition();
            recognition.lang = 'hi-IN';
            recognition.continuous = false;
            recognition.interimResults = false;
            recognition.maxAlternatives = 1;

            recognition.onstart = () => {
                isListening = true;
                btnMic.classList.add('listening');
                elAiStatus.innerText = "Listening... Speak A, B, C, or D";
            };

            recognition.onresult = (e) => {
                const transcript = e.results[0][0].transcript.trim().toLowerCase();
                processVoice(transcript);
            };

            recognition.onerror = () => { stopMic(); elAiStatus.innerText = "Voice not clear. Try again."; };
            recognition.onend = () => { stopMic(); };
        } else {
            console.warn("Speech API not supported.");
        }

        function toggleMic() {
            if(!recognition) { alert("Your browser doesn't support Voice Answer."); return; }
            if(isListening) recognition.stop();
            else {
                if(!isAnswering && !isPaused) {
                    synth.cancel(); // stop teacher talking
                    recognition.start();
                }
            }
        }
        function stopMic() { isListening = false; btnMic.classList.remove('listening'); }

        function processVoice(text) {
            if(isAnswering || isPaused) return;
            let sel = -1;
            const mapA = ["a", "ए", "वन", "1", "पहला", "option a", "विकल्प ए"];
            const mapB = ["b", "बी", "टू", "2", "दूसरा", "option b", "विकल्प बी"];
            const mapC = ["c", "सी", "थ्री", "3", "तीसरा", "option c", "विकल्प सी"];
            const mapD = ["d", "डी", "फोर", "4", "चौथा", "option d", "विकल्प डी"];

            if(mapA.some(v => text.includes(v))) sel = 0;
            else if(mapB.some(v => text.includes(v))) sel = 1;
            else if(mapC.some(v => text.includes(v))) sel = 2;
            else if(mapD.some(v => text.includes(v))) sel = 3;

            if(sel !== -1) checkAnswer(sel);
            else {
                elAiStatus.innerText = "Invalid option. Say Option A, B, C or D.";
                speakText("क्षमा करें, मुझे समझ नहीं आया। कृपया विकल्प ए, बी, सी या डी बोलें।");
            }
        }

        /* =========================================
           6. CORE LOGIC & UI UPDATES
        ========================================= */
        function switchScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function initClassroom() {
            startTime = Date.now();
            setVoice();
            // Opening Welcome Dialogue
            const introText = "नमस्कार विद्यार्थी! स्वागत है आपका ललन कुमार द्वारा बनाए गए इस शानदार स्मार्ट केमिस्ट्री क्लासरूम में। आज हम एप्लाइड केमिस्ट्री बी का वॉइस क्विज़ खेलने वाले हैं। इस क्विज़ में कुल 50 प्रश्न होंगे। प्रत्येक प्रश्न के लिए 30 सेकंड का समय मिलेगा। आप माइक्रोफोन का उपयोग करके उत्तर दे सकते हैं। क्या आप तैयार हैं? चलिए शुरू करते हैं, शुभकामनाएँ।";
            
            speakText(introText, () => {
                switchScreen('quiz-screen');
                loadQuestion();
            });
        }

        function loadQuestion() {
            if(currentQIndex >= questions.length) { showResults(); return; }
            
            isAnswering = false;
            isPaused = false;
            elAiStatus.innerText = "AI Teacher is ready...";
            
            const q = questions[currentQIndex];
            
            // Update UI Counters
            document.getElementById('q-num').innerText = `Question ${currentQIndex + 1} of 50 | ${q.u}`;
            document.getElementById('q-text').innerText = q.q;
            document.getElementById('score-val').innerText = scoreXP;
            
            const progress = (currentQIndex / 50) * 100;
            document.getElementById('progress-fill').style.width = `${progress}%`;

            // Options
            const optGrid = document.getElementById('options-grid');
            optGrid.innerHTML = '';
            const labels = ['A', 'B', 'C', 'D'];
            let readText = `${q.q}. `;

            q.o.forEach((opt, idx) => {
                let div = document.createElement('div');
                div.className = 'option-btn chalk-text';
                div.innerHTML = `<strong>Option ${labels[idx]}:</strong> ${opt}`;
                div.onclick = () => checkAnswer(idx);
                optGrid.appendChild(div);
                readText += `विकल्प ${labels[idx]}... ${opt}... `;
            });

            startTimer();
            speakText(readText);
        }

        function repeatQuestion() {
            if(isAnswering || isPaused) return;
            const q = questions[currentQIndex];
            let readText = `${q.q}. विकल्प ए, ${q.o[0]}. विकल्प बी, ${q.o[1]}. विकल्प सी, ${q.o[2]}. विकल्प डी, ${q.o[3]}.`;
            speakText(readText);
        }

        function togglePause() {
            if(isAnswering) return;
            const btn = document.getElementById('pause-btn');
            if(isPaused) {
                isPaused = false;
                btn.innerText = "⏸";
                elAiStatus.innerText = "Quiz Resumed";
                timerInterval = setInterval(timerTick, 1000);
            } else {
                isPaused = true;
                btn.innerText = "▶";
                elAiStatus.innerText = "Quiz Paused";
                clearInterval(timerInterval);
                synth.cancel();
            }
        }

        /* --- TIMER --- */
        const elTimerText = document.getElementById('timer-text');
        const elTimerCircle = document.getElementById('timer-circle');

        function startTimer() {
            clearInterval(timerInterval);
            timeLeft = 30;
            updateTimerUI();
            timerInterval = setInterval(timerTick, 1000);
        }

        function timerTick() {
            if(isPaused) return;
            timeLeft--;
            updateTimerUI();
            if(timeLeft <= 0) {
                clearInterval(timerInterval);
                handleTimeOut();
            }
        }

        function updateTimerUI() {
            elTimerText.innerText = timeLeft;
            const dashoffset = 220 - (timeLeft / 30) * 220;
            elTimerCircle.style.strokeDashoffset = dashoffset;

            // Color Warning
            if(timeLeft > 15) elTimerCircle.style.stroke = "var(--neon-green)";
            else if(timeLeft > 5) elTimerCircle.style.stroke = "var(--yellow)";
            else elTimerCircle.style.stroke = "var(--red)";
        }

        function handleTimeOut() {
            if(isAnswering) return;
            isAnswering = true;
            synth.cancel();
            if(isListening && recognition) recognition.stop();

            const q = questions[currentQIndex];
            document.getElementById('options-grid').children[q.a].classList.add('correct');
            wrongCount++;
            document.getElementById('wrong-count').innerText = wrongCount;
            elAiStatus.innerText = "Time Out!";

            speakText("समय समाप्त हो गया है। अब अगले प्रश्न पर चलते हैं।", nextQuestion);
        }

        /* --- ANSWER CHECK --- */
        function checkAnswer(selIdx) {
            if(isAnswering || isPaused) return;
            isAnswering = true;
            clearInterval(timerInterval);
            synth.cancel();
            if(isListening && recognition) recognition.stop();

            const q = questions[currentQIndex];
            const opts = document.getElementById('options-grid').children;
            
            if(selIdx === q.a) {
                opts[selIdx].classList.add('correct');
                scoreXP += (10 + Math.floor(timeLeft/2)); // XP bonus for time
                correctCount++;
                unitStats[q.u].correct++;
                document.getElementById('correct-count').innerText = correctCount;
                document.getElementById('score-val').innerText = scoreXP;
                elAiStatus.innerText = "Correct Answer!";
                
                speakText("बहुत बढ़िया विद्यार्थी! आपका उत्तर बिल्कुल सही है। इसी प्रकार मेहनत करते रहिए।", nextQuestion);
            } else {
                opts[selIdx].classList.add('wrong');
                opts[q.a].classList.add('correct');
                wrongCount++;
                document.getElementById('wrong-count').innerText = wrongCount;
                elAiStatus.innerText = "Wrong Answer!";
                
                speakText("कोई बात नहीं विद्यार्थी। गलतियों से ही सीख मिलती है। अगले प्रश्न में बेहतर प्रयास करें।", nextQuestion);
            }
        }

        function nextQuestion() {
            currentQIndex++;
            setTimeout(loadQuestion, 500);
        }

        /* =========================================
           7. RESULTS & CEREMONY
        ========================================= */
        function showResults() {
            switchScreen('result-screen');
            synth.cancel();
            
            const total = 50;
            const percent = Math.round((correctCount / total) * 100);
            const timeTakenStr = `${Math.floor((Date.now()-startTime)/60000)}m ${Math.floor(((Date.now()-startTime)%60000)/1000)}s`;

            document.getElementById('res-correct').innerText = correctCount;
            document.getElementById('res-wrong').innerText = wrongCount;
            document.getElementById('res-percent').innerText = percent + "%";
            document.getElementById('res-xp').innerText = scoreXP;
            document.getElementById('res-time').innerText = timeTakenStr;

            // Ranking Logic
            let rank, badge, speech;
            if(percent >= 90) {
                rank = "Chemistry Genius"; badge = "👑";
                speech = "वाह विद्यार्थी! आपने शानदार प्रदर्शन किया है। आप केमिस्ट्री जीनियस घोषित किए जाते हैं। आपकी मेहनत और लगन वास्तव में प्रेरणादायक है। ऐसे ही पढ़ाई करते रहिए और जीवन में बड़ी सफलता प्राप्त कीजिए। ललन कुमार स्मार्ट क्लासरूम की ओर से आपको हार्दिक शुभकामनाएँ।";
            } else if(percent >= 70) {
                rank = percent >= 80 ? "Top Performer" : "Excellent Student"; badge = "🥇";
                speech = "बहुत बढ़िया विद्यार्थी। आपने उत्कृष्ट प्रदर्शन किया है। थोड़ी और मेहनत आपको शीर्ष स्थान तक पहुँचा सकती है। लगातार अभ्यास करते रहिए।";
            } else if(percent >= 50) {
                rank = percent >= 60 ? "Good Student" : "Average Student"; badge = "🥈";
                speech = "विद्यार्थी, आपने अच्छा प्रयास किया है, लेकिन आपको और अभ्यास की आवश्यकता है। मेहनत करते रहिए।";
            } else {
                rank = "Need More Practice"; badge = "📚";
                speech = "विद्यार्थी, निराश होने की आवश्यकता नहीं है। हर सफलता की शुरुआत अभ्यास से होती है। दोबारा प्रयास करें और अपने ज्ञान को और मजबूत बनाएं। आप निश्चित रूप से सफल होंगे।";
            }

            document.getElementById('rank-title').innerText = rank;
            document.getElementById('rank-badge').innerText = badge;

            // Analytics Table
            const table = document.getElementById('analytics-table');
            for(let key in unitStats) {
                let u = unitStats[key];
                let acc = Math.round((u.correct / u.total) * 100);
                table.innerHTML += `<tr><td>${key.split(':')[1]}</td><td>${u.total}</td><td>${u.correct}</td><td>${acc}%</td></tr>`;
            }

            // Confetti if passing
            if(percent >= 50) shootConfetti();

            speakText(speech);
        }

        /* =========================================
           8. EXTRA PREMIUM FEATURES
        ========================================= */
        
        // Theme Toggle
        function toggleTheme() {
            const html = document.documentElement;
            html.dataset.theme = html.dataset.theme === "dark" ? "light" : "dark";
        }

        // Fullscreen Toggle
        function toggleFullScreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(err => {
                    console.log(`Error attempting to enable fullscreen: ${err.message}`);
                });
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                }
            }
        }

        // Lightweight Confetti Particle System
        function shootConfetti() {
            const canvas = document.getElementById('confetti-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            let particles = [];
            for(let i=0; i<150; i++) {
                particles.push({
                    x: canvas.width / 2, y: canvas.height / 2,
                    r: Math.random() * 6 + 2,
                    dx: Math.random() * 20 - 10, dy: Math.random() * -20 - 5,
                    color: `hsl(${Math.random()*360}, 100%, 50%)`,
                    tilt: Math.random() * 10
                });
            }

            function animate() {
                requestAnimationFrame(animate);
                ctx.clearRect(0,0,canvas.width,canvas.height);
                particles.forEach(p => {
                    p.dy += 0.5; // gravity
                    p.x += p.dx; p.y += p.dy; p.tilt += 0.1;
                    ctx.beginPath();
                    ctx.lineWidth = p.r; ctx.strokeStyle = p.color;
                    ctx.moveTo(p.x + p.tilt + p.r, p.y);
                    ctx.lineTo(p.x + p.tilt, p.y + p.tilt + p.r);
                    ctx.stroke();
                });
            }
            animate();
            setTimeout(() => { canvas.style.opacity = 0; }, 5000); // fade out
        }

        // Initialization trigger
        window.onload = () => { setVoice(); };

    </script>
