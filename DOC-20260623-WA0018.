<!DOCTYPE html>
<html lang="hi" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lalan Kumar - Chemistry Smart Classroom</title>
    <style>
        /* --- CSS VARIABLES --- */
        :root[data-theme="dark"] {
            --board-bg: #112211;
            --board-border: #5c4033;
            --text-main: #f4f4f4;
            --text-glow: rgba(255, 255, 255, 0.7);
            --neon-green: #39ff14;
            --yellow: #f1c40f;
            --red: #e74c3c;
            --chalk-dust: rgba(255, 255, 255, 0.03);
            --option-bg: rgba(255, 255, 255, 0.05);
            --option-hover: rgba(57, 255, 20, 0.2);
            --shadow-color: rgba(0, 0, 0, 0.8);
        }

        :root[data-theme="light"] {
            --board-bg: #ffffff;
            --board-border: #bdc3c7;
            --text-main: #2c3e50;
            --text-glow: rgba(0, 0, 0, 0.2);
            --neon-green: #27ae60;
            --yellow: #f39c12;
            --red: #c0392b;
            --chalk-dust: rgba(0, 0, 0, 0.02);
            --option-bg: rgba(0, 0, 0, 0.05);
            --option-hover: rgba(39, 174, 96, 0.2);
            --shadow-color: rgba(0, 0, 0, 0.2);
        }

        /* --- GLOBAL STYLES --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Comic Sans MS', 'Chalkboard SE', 'Segoe Print', cursive;
        }

        body {
            background-color: #050505;
            color: var(--text-main);
            overflow-x: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            user-select: none;
        }

        /* --- BACKGROUND ANIMATIONS --- */
        .bg-animations {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            pointer-events: none;
            overflow: hidden;
        }

        .atom {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(57, 255, 20, 0.2);
            animation: float 10s infinite linear;
        }

        .atom::before, .atom::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            border: 1px dashed rgba(57, 255, 20, 0.3);
            animation: spin 5s infinite linear;
        }

        .atom::before { width: 120%; height: 40%; }
        .atom::after { width: 40%; height: 120%; }

        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            50% { opacity: 1; }
            100% { transform: translateY(-20vh) rotate(360deg); opacity: 0; }
        }

        @keyframes spin { 100% { transform: translate(-50%, -50%) rotate(360deg); } }

        /* --- SMART BOARD --- */
        .smart-board {
            width: 95vw;
            max-width: 1200px;
            height: 90vh;
            background: var(--board-bg);
            background-image: radial-gradient(var(--chalk-dust) 1px, transparent 1px);
            background-size: 10px 10px;
            border: 15px solid var(--board-border);
            border-radius: 10px;
            box-shadow: inset 0 0 50px rgba(0,0,0,0.5), 0 15px 35px var(--shadow-color);
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.5s ease;
        }

        /* Chalk Text Effect */
        .chalk-text {
            text-shadow: 0 0 2px var(--text-glow), 0 0 5px var(--text-glow);
        }

        /* --- SCREENS --- */
        .screen {
            display: none;
            width: 100%;
            height: 100%;
            padding: 30px;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            animation: fadeIn 1s ease-in-out;
        }

        .screen.active { display: flex; }

        @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

        /* --- TOP BAR CONTROLS --- */
        .top-controls {
            position: absolute;
            top: 15px; right: 20px;
            display: flex;
            gap: 15px;
            z-index: 10;
        }

        .ctrl-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid var(--text-main);
            color: var(--text-main);
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            transition: 0.3s;
        }
        .ctrl-btn:hover { background: var(--neon-green); color: #000; }

        /* --- WELCOME SCREEN --- */
        .teacher-avatar {
            font-size: 80px;
            animation: bounce 2s infinite;
            filter: drop-shadow(0 0 10px var(--neon-green));
            margin-bottom: 20px;
        }

        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

        .welcome-title {
            font-size: 3rem;
            color: var(--neon-green);
            text-align: center;
            margin-bottom: 15px;
            letter-spacing: 2px;
        }

        .welcome-subtitle { font-size: 1.5rem; margin-bottom: 40px; text-align: center; }

        .btn-start {
            background: transparent;
            color: var(--neon-green);
            border: 2px solid var(--neon-green);
            padding: 15px 40px;
            font-size: 1.8rem;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 0 15px rgba(57, 255, 20, 0.4);
        }

        .btn-start:hover {
            background: var(--neon-green);
            color: var(--board-bg);
            box-shadow: 0 0 30px var(--neon-green);
            transform: scale(1.05);
        }

        /* --- QUIZ SCREEN --- */
        .quiz-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px dashed var(--text-glow);
            padding-bottom: 10px;
        }

        .stats-box { font-size: 1.2rem; display: flex; gap: 20px; }
        .correct-text { color: var(--neon-green); }
        .wrong-text { color: var(--red); }

        .timer-container {
            position: relative;
            width: 80px; height: 80px;
        }

        .timer-svg { transform: rotate(-90deg); width: 100%; height: 100%; }
        .timer-circle-bg { fill: none; stroke: rgba(255,255,255,0.1); stroke-width: 6; }
        .timer-circle {
            fill: none; stroke: var(--neon-green); stroke-width: 6;
            stroke-dasharray: 220; stroke-dashoffset: 0;
            transition: stroke-dashoffset 1s linear, stroke 0.5s ease;
        }
        .timer-text {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            font-size: 1.5rem; font-weight: bold;
        }

        .progress-bar-container { width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; margin-bottom: 20px; }
        .progress-fill { height: 100%; background: var(--neon-green); width: 0%; transition: width 0.3s; border-radius: 4px; box-shadow: 0 0 10px var(--neon-green); }

        .question-box { text-align: center; margin-bottom: 30px; width: 100%; }
        .question-num { font-size: 1.2rem; color: var(--yellow); margin-bottom: 10px; }
        .question-text { font-size: 2.2rem; line-height: 1.4; }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            width: 100%;
            max-width: 900px;
        }

        .option-btn {
            background: var(--option-bg);
            border: 1px solid var(--text-glow);
            color: var(--text-main);
            padding: 20px;
            font-size: 1.3rem;
            border-radius: 10px;
            cursor: pointer;
            text-align: left;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .option-btn:hover { background: var(--option-hover); border-color: var(--neon-green); transform: translateY(-2px); }
        .option-btn.correct { background: rgba(57, 255, 20, 0.3); border-color: var(--neon-green); box-shadow: 0 0 15px var(--neon-green); }
        .option-btn.wrong { background: rgba(231, 76, 60, 0.3); border-color: var(--red); box-shadow: 0 0 15px var(--red); }

        .controls-footer {
            margin-top: auto; width: 100%; display: flex; justify-content: center; gap: 20px; padding-top: 20px;
        }
        
        .mic-btn {
            width: 70px; height: 70px; border-radius: 50%;
            background: transparent; border: 2px solid var(--text-main); color: var(--text-main);
            font-size: 30px; cursor: pointer; transition: 0.3s; display: flex; justify-content: center; align-items: center;
        }
        .mic-btn.listening {
            border-color: var(--red); color: var(--red); animation: pulseMic 1s infinite;
        }
        @keyframes pulseMic { 0% { box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(231, 76, 60, 0); } }

        .ai-status { margin-top: 10px; font-size: 1.1rem; color: var(--yellow); min-height: 25px; text-align: center; }

        /* --- RESULT SCREEN --- */
        .result-title { font-size: 3.5rem; color: var(--neon-green); margin-bottom: 10px; }
        .rank-badge { font-size: 60px; filter: drop-shadow(0 0 15px gold); margin: 10px 0; }
        .result-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; width: 100%; max-width: 800px; margin: 20px 0; }
        .res-box { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 10px; border: 1px dashed var(--text-glow); text-align: center; }
        .res-val { font-size: 2rem; font-weight: bold; color: var(--neon-green); }
        
        .analytics-table { width: 100%; max-width: 800px; margin-top: 20px; border-collapse: collapse; font-size: 1rem; }
        .analytics-table th, .analytics-table td { border: 1px solid var(--text-glow); padding: 8px; text-align: center; }
        .analytics-table th { color: var(--yellow); }

        .action-btns { display: flex; gap: 15px; margin-top: 30px; }

        /* Canvas for Confetti */
        #confetti-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 99; }

        @media (max-width: 768px) {
            .options-grid { grid-template-columns: 1fr; }
            .result-grid { grid-template-columns: 1fr 1fr; }
            .question-text { font-size: 1.5rem; }
            .welcome-title { font-size: 2rem; }
        }

        /* Print Styles */
        @media print {
            body { background: white; color: black; }
            .smart-board { border: none; box-shadow: none; width: 100%; height: auto; }
            .top-controls, .action-btns, .bg-animations { display: none; }
            .chalk-text { text-shadow: none; }
            * { color: black !important; }
        }
    </style>
</head>
<body>

    <div class="bg-animations" id="bg-anims"></div>

    <div class="smart-board">
        <canvas id="confetti-canvas"></canvas>

        <div class="top-controls">
            <button class="ctrl-btn" onclick="toggleTheme()" title="Toggle Theme">🌗</button>
            <button class="ctrl-btn" onclick="toggleFullScreen()" title="Full Screen">⛶</button>
        </div>

        <!-- WELCOME SCREEN -->
        <div id="welcome-screen" class="screen active chalk-text">
            <div class="teacher-avatar">👨‍🏫</div>
            <h1 class="welcome-title">Chemistry Smart Classroom</h1>
            <h2 class="welcome-subtitle">By Lalan Kumar (Applied Chemistry-B)</h2>
            <div style="max-width: 600px; text-align: center; font-size: 1.2rem; margin-bottom: 30px; line-height: 1.6;">
                🧪 50 महत्वपूर्ण प्रश्न (Unit 1 to 5)<br>
                ⏱ 30 सेकंड प्रति प्रश्न<br>
                🎤 वॉयस रिकग्निशन आधारित उत्तर (A, B, C, D)<br>
                🎓 AI Teacher के साथ लाइव अनुभव
            </div>
            <button class="btn-start" onclick="initClassroom()">Enter Classroom</button>
        </div>

        <!-- QUIZ SCREEN -->
        <div id="quiz-screen" class="screen chalk-text">
            <div class="quiz-header">
                <div class="stats-box">
                    <span>Score: <span id="score-val" class="correct-text">0</span> XP</span>
                    <span><span class="correct-text">✔</span> <span id="correct-count">0</span></span>
                    <span><span class="wrong-text">✖</span> <span id="wrong-count">0</span></span>
                </div>
                <div class="timer-container">
                    <svg class="timer-svg" viewBox="0 0 80 80">
                        <circle class="timer-circle-bg" cx="40" cy="40" r="35"></circle>
                        <circle class="timer-circle" id="timer-circle" cx="40" cy="40" r="35"></circle>
                    </svg>
                    <div class="timer-text" id="timer-text">30</div>
                </div>
            </div>

            <div class="progress-bar-container">
                <div class="progress-fill" id="progress-fill"></div>
            </div>

            <div class="question-box">
                <div class="question-num" id="q-num">Question 1 of 50 | Unit: Atomic Structure</div>
                <div class="question-text" id="q-text">प्रश्न यहाँ आएगा?</div>
            </div>

            <div class="options-grid" id="options-grid">
                <!-- Options injected by JS -->
            </div>

            <div class="controls-footer">
                <button class="ctrl-btn" style="font-size: 24px;" onclick="repeatQuestion()" title="Repeat Question">🔊</button>
                <button class="mic-btn" id="mic-btn" onclick="toggleMic()" title="Tap & Speak (A,B,C,D)">🎤</button>
                <button class="ctrl-btn" style="font-size: 24px;" id="pause-btn" onclick="togglePause()" title="Pause/Resume">⏸</button>
            </div>
            <div class="ai-status" id="ai-status">AI Teacher is ready...</div>
        </div>

        <!-- RESULT SCREEN -->
        <div id="result-screen" class="screen chalk-text">
            <h1 class="result-title">Ceremony Completed</h1>
            <div class="rank-badge" id="rank-badge">🏆</div>
            <h2 id="rank-title" style="color: var(--yellow); font-size: 2rem; margin-bottom: 10px;">Chemistry Genius</h2>
            
            <div class="result-grid">
                <div class="res-box"><div class="res-val">50</div><div>Total Qs</div></div>
                <div class="res-box"><div class="res-val correct-text" id="res-correct">0</div><div>Correct</div></div>
                <div class="res-box"><div class="res-val wrong-text" id="res-wrong">0</div><div>Wrong</div></div>
                <div class="res-box"><div class="res-val" id="res-percent">0%</div><div>Percentage</div></div>
                <div class="res-box"><div class="res-val" id="res-xp" style="color: #9b59b6;">0</div><div>XP Earned</div></div>
                <div class="res-box"><div class="res-val" id="res-time">0m 0s</div><div>Time Taken</div></div>
            </div>

            <!-- Unit Analytics -->
            <table class="analytics-table" id="analytics-table">
                <tr><th>Unit</th><th>Questions</th><th>Correct</th><th>Accuracy</th></tr>
                <!-- Populated by JS -->
            </table>

            <div class="action-btns">
                <button class="btn-start" style="padding: 10px 20px; font-size: 1.2rem;" onclick="location.reload()">Restart</button>
                <button class="btn-start" style="padding: 10px 20px; font-size: 1.2rem;" onclick="window.print()">Print Certificate</button>
            </div>
        </div>
    </div>

    <script>
        /* =========================================
           1. QUESTIONS DATABASE (50 Questions SBTE)
        ========================================= */
        const questions = [
            // Unit 1: Atomic Structure (12)
            { u: "Unit-1: Atomic Structure", q: "इलेक्ट्रॉन की खोज किसने की थी?", o: ["जे. जे. थॉमसन", "रदरफोर्ड", "चैडविक", "नील्स बोर"], a: 0 },
            { u: "Unit-1: Atomic Structure", q: "प्रोटॉन पर कौन सा आवेश (Charge) होता है?", o: ["ऋणात्मक", "धनात्मक", "उदासीन", "इनमें से कोई नहीं"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "न्यूट्रॉन की खोज किस वैज्ञानिक ने की?", o: ["रदरफोर्ड", "गोल्डस्टीन", "चैडविक", "थॉमसन"], a: 2 },
            { u: "Unit-1: Atomic Structure", q: "परमाणु के नाभिक (Nucleus) में मुख्य रूप से क्या पाए जाते हैं?", o: ["इलेक्ट्रॉन और प्रोटॉन", "प्रोटॉन और न्यूट्रॉन", "केवल इलेक्ट्रॉन", "इलेक्ट्रॉन और न्यूट्रॉन"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "समस्थानिक (Isotopes) में क्या समान होता है?", o: ["द्रव्यमान संख्या", "परमाणु क्रमांक", "न्यूट्रॉन की संख्या", "भौतिक गुण"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "क्वांटम संख्याएँ (Quantum numbers) कितने प्रकार की होती हैं?", o: ["2", "3", "4", "5"], a: 2 },
            { u: "Unit-1: Atomic Structure", q: "d-ऑर्बिटल (d-orbital) में अधिकतम कितने इलेक्ट्रॉन रह सकते हैं?", o: ["2", "6", "10", "14"], a: 2 },
            { u: "Unit-1: Atomic Structure", q: "ऑफबाऊ सिद्धांत (Aufbau Principle) किससे संबंधित है?", o: ["नाभिक के आकार से", "इलेक्ट्रॉन भरने के क्रम से", "न्यूट्रॉन की खोज से", "समस्थानिक से"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "पाऊली का अपवर्जन सिद्धांत क्या कहता है?", o: ["कक्षा गोलाकार होती है", "कोई भी 2 इलेक्ट्रॉन की 4 क्वांटम संख्याएँ समान नहीं हो सकतीं", "इलेक्ट्रॉन ऊर्जा का उत्सर्जन करते हैं", "नाभिक धनावेशित होता है"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "हुंड का नियम (Hund's Rule) किससे संबंधित है?", o: ["अधिकतम बहुलता से", "न्यूनतम ऊर्जा से", "द्रव्यमान संरक्षण से", "ऊर्जा संरक्षण से"], a: 0 },
            { u: "Unit-1: Atomic Structure", q: "बोर के परमाणु मॉडल के अनुसार इलेक्ट्रॉन कहाँ घूमते हैं?", o: ["नाभिक के अंदर", "निश्चित वृत्ताकार कक्षाओं में", "टेढ़े-मेढ़े रास्ते पर", "कहीं भी नहीं"], a: 1 },
            { u: "Unit-1: Atomic Structure", q: "किसी तत्व का परमाणु क्रमांक किसके बराबर होता है?", o: ["न्यूट्रॉन की संख्या", "प्रोटॉन की संख्या", "द्रव्यमान संख्या", "परमाणु भार"], a: 1 },
            
            // Unit 2: Water (10)
            { u: "Unit-2: Water", q: "जल की स्थायी कठोरता (Permanent Hardness) का मुख्य कारण क्या है?", o: ["कैल्शियम व मैग्नीशियम के बाइकार्बोनेट", "कैल्शियम व मैग्नीशियम के क्लोराइड और सल्फेट", "सोडियम क्लोराइड", "पोटेशियम सल्फेट"], a: 1 },
            { u: "Unit-2: Water", q: "जल की अस्थायी कठोरता को कैसे दूर किया जा सकता है?", o: ["छानकर", "उबाल कर", "ठंडा करके", "फिटकरी डालकर"], a: 1 },
            { u: "Unit-2: Water", q: "pH स्केल का परास (Range) क्या होता है?", o: ["1 से 10", "0 से 14", "1 से 100", "0 से 7"], a: 1 },
            { u: "Unit-2: Water", q: "शुद्ध जल का pH मान कितना होता है?", o: ["5", "6", "7", "8"], a: 2 },
            { u: "Unit-2: Water", q: "BOD का पूर्ण रूप (Full Form) क्या है?", o: ["Biological Oxygen Demand", "Biochemical Oxygen Demand", "Basic Oxygen Demand", "Biochemical Oxidation Demand"], a: 1 },
            { u: "Unit-2: Water", q: "EDTA विधि का उपयोग किसके लिए किया जाता है?", o: ["जल का pH मापने", "जल की कठोरता मापने", "तापमान मापने", "BOD मापने"], a: 1 },
            { u: "Unit-2: Water", q: "परम्यूटिट (Permutit) का रासायनिक नाम क्या है?", o: ["सोडियम क्लोराइड", "सोडियम एल्युमिनियम सिलिकेट", "कैल्शियम कार्बोनेट", "मैग्नीशियम सल्फेट"], a: 1 },
            { u: "Unit-2: Water", q: "पीने योग्य जल (Potable water) में कॉलिफॉर्म (Coliform) बैक्टीरिया की मात्रा कितनी होनी चाहिए?", o: ["शून्य", "10 प्रति 100 ml", "50 प्रति 100 ml", "100 प्रति 100 ml"], a: 0 },
            { u: "Unit-2: Water", q: "जल के रोगाणुनाशन (Disinfection) के लिए आमतौर पर किसका उपयोग किया जाता है?", o: ["सोडियम", "क्लोरीन", "कार्बन", "ऑक्सीजन"], a: 1 },
